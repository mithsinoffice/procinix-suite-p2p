NODE_ENV=production
PORT=8787

# ── Auth ──────────────────────────────────────────────────────────────────────
# REQUIRED in production. If unset, API auth is disabled (dev only — see B3).
API_SECRET_KEY=

# Comma-separated emails allowed to call /api/admin/* (tenant & platform entity CRUD).
# Must match the operator signing in on the Super admin console (X-User-Email).
SUPER_ADMIN_EMAILS=

# ── Database (REQUIRED) ───────────────────────────────────────────────────────
MYSQL_HOST=your-server.mysql.database.azure.com
MYSQL_PORT=3306
MYSQL_DATABASE=p2p_schema_mt
MYSQL_USER=your-username
MYSQL_PASSWORD=your-password
MYSQL_SSL_MODE=required

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://your-domain.com

# ── AI / OCR (REQUIRED — at least one OCR provider must be set) ───────────────
# Option A: Google Gemini (primary OCR for invoice extraction)
GOOGLE_AI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

# Option B: n8n webhook (alternative OCR pipeline — used if GOOGLE_AI_API_KEY is unset)
N8N_WEBHOOK_URL=https://vishkar.app.n8n.cloud/webhook/invoice-extract

# REQUIRED: Anthropic Claude for agent reasoning (vendor match, tax, routing)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Email — Inbound (IMAP invoice ingestion, optional) ───────────────────────
AP_EMAIL_HOST=imap.gmail.com
AP_EMAIL_PORT=993
AP_EMAIL_USER=
AP_EMAIL_PASSWORD=
AP_EMAIL_INBOX=INBOX
AP_POLL_INTERVAL_MINUTES=5

# ── Email — Outbound (SMTP, optional but required for notifications) ──────────
# If AP_EMAIL_* IMAP is configured and SMTP_HOST is absent, a warning is logged at startup.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
# Recipient for agent pipeline failure alerts; falls back to MAIL_FROM if unset.
ALERTS_EMAIL=

# ── Frontend ──────────────────────────────────────────────────────────────────
# REQUIRED. Must end with /api.
# Dev with local server:   VITE_API_BASE_URL=http://127.0.0.1:8787/api
# Dev with Vite proxy:     VITE_API_BASE_URL=/api
VITE_API_BASE_URL=/api

# Same emails as SUPER_ADMIN_EMAILS — used client-side to show Super admin nav (comma-separated).
VITE_SUPER_ADMIN_EMAILS=

# ── KYC (optional, mock mode by default) ─────────────────────────────────────
KYC_PROVIDER=ongrid
ONGRID_API_KEY=
ONGRID_BASE_URL=https://api.gridlines.io
ONGRID_SANDBOX_URL=https://api.gridlines.io
ONGRID_MOCK_MODE=true
