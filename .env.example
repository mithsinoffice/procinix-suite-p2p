DATABASE_URL="mysql://procinix:procinix_dev@localhost:3306/procinix_v2"
# Shadow database — required for `prisma migrate dev`. Must be writable by a
# user with CREATE/DROP on this database. Local dev typically points at a
# separate empty schema; CI / Azure use a transient one.
SHADOW_DATABASE_URL="mysql://root@localhost:3306/procinix_shadow"
# SMTP relay for transactional outbound emails (vendor invitations,
# approval/rejection notices, change-request status). Leave SMTP_HOST
# empty in dev — the email service falls back to console logging.
# Production: any SMTP relay (SendGrid, Postmark, AWS SES SMTP, Azure
# Communication Services SMTP, custom).
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Procinix Vendor Portal <no-reply@procinix.com>"
REDIS_URL="redis://localhost:6379"
JWT_SECRET="REPLACE_WITH_SECURE_RANDOM_SECRET_MIN_32_CHARS_LONG"
JWT_REFRESH_SECRET="REPLACE_WITH_DIFFERENT_SECURE_RANDOM_SECRET_HERE"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
COOKIE_SECRET="REPLACE_WITH_32_CHAR_COOKIE_SIGNING_SECRET!!"
NODE_ENV="development"
PORT="8787"
HOST="0.0.0.0"
FRONTEND_URL="http://localhost:3000"
# Gemini OCR
GEMINI_API_KEY=AIzaSyBaw7E0lz3_B3FkW3UsikSVey-rJ6wc1Gs
GEMINI_MODEL="gemini-1.5-flash"

# N8N email ingestion webhook
N8N_WEBHOOK_SECRET=https://vishkar.app.n8n.cloud/webhook/invoice-extract

# OpenAI — async invoice scoring (gpt-4o-mini) fired after n8n ingest.
# If missing, scoring falls back gracefully — invoice stays needs_review.
OPENAI_API_KEY=your-openai-api-key-here

# Invoice ingestion
INVOICE_EMAIL_ADDRESS="procinixvm@gmail.com"
STP_SCORE_THRESHOLD="95"
STP_AMOUNT_CEILING="500000"

