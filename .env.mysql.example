APP_PORT=8787
MYSQL_HOST=p2p-procinix-mysql-dev-db.mysql.database.azure.com
MYSQL_PORT=3306
MYSQL_DATABASE=p2p_schema_mt
MYSQL_USER=adminprocinix
MYSQL_PASSWORD="replace-me"
MYSQL_SSL_MODE=required

# Transactional email (vendor invitations, etc.). From defaults to info@procinix.ai; override with MAIL_FROM.
# If SMTP_HOST is unset, send is mocked (200 + mock:true, no delivery).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=info@procinix.ai
