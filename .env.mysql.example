APP_PORT=8787

# API authentication — set a strong secret. If empty, auth is disabled (dev mode only).
API_SECRET_KEY=

# Super admin console (/super-admin): comma-separated operator emails (must match signed-in user).
SUPER_ADMIN_EMAILS=

# Comma-separated list of allowed CORS origins. Defaults to localhost:3000.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
MYSQL_HOST=p2p-procinix-mysql-dev-db.mysql.database.azure.com
MYSQL_PORT=3306
MYSQL_DATABASE=p2p_schema_mt
MYSQL_USER=adminprocinix
MYSQL_PASSWORD=d!ss#aSj0
MYSQL_SSL_MODE=required
# Optional: path to Azure CA cert (DigiCertGlobalRootG2.crt.pem).
# If omitted, the system CA store is used (works on most platforms).
MYSQL_SSL_CA=

# Transactional email (vendor invitations, etc.). From defaults to info@procinix.ai; override with MAIL_FROM.
# If SMTP_HOST is unset, send is mocked (200 + mock:true, no delivery).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=info@procinix.ai

# AI Invoice Ingestion — Email (leave AP_EMAIL_HOST empty to disable polling)
AP_EMAIL_HOST=imap.gmail.com
AP_EMAIL_PORT=993
AP_EMAIL_USER=ap@yourcompany.com
AP_EMAIL_PASSWORD=your-app-password
AP_EMAIL_INBOX=INBOX
AP_POLL_INTERVAL_MINUTES=90

# AI Invoice Ingestion — Gemini OCR (only supported provider)
GOOGLE_AI_API_KEY=your-google-ai-api-key
GEMINI_MODEL=gemini-2.5-pro
# Optional: execute active AgentBuilder agents during ingestion runtime
# Safe rollout: keep false unless you want custom agents in live pipeline.
ENABLE_AGENT_BUILDER_RUNTIME=false

# AI Invoice Ingestion — Notifications
AP_NOTIFICATION_EMAIL=info@procinix.ai
