            "typescript": "^6.0.2",
            "vite": "^6.4.2",
            "vitest": "^4.1.4",
            "wait-on": "^9.0.4"
      },
      "scripts": {
            "dev": "concurrently --kill-others-on-fail --restart-tries 1 --restart-delay 1500 -n api,web -c blue,green \"npm run server:mysql:fresh\" \"wait-on -t 120000 tcp:127.0.0.1:8787 && npm run dev:web\"",
            "dev:web": "vite",
            "dev:full": "npm run dev",
            "build": "vite build",
            "test": "vitest run",
            "typecheck": "tsc --noEmit",
            "start": "NODE_ENV=production node server/index.mjs",
            "server:mysql": "node --env-file=.env.mysql.local server/index.mjs",
            "server:mysql:fresh": "sh -c 'PID=$(lsof -ti tcp:8787); if [ -n \"$PID\" ]; then kill $PID || true; sleep 1; fi; node --env-file=.env.mysql.local server/index.mjs'",
            "migrate:tenant-schema": "node --env-file=.env.mysql.local server/scripts/runMultiTenancyMigration.mjs",
            "migrate:tenant-schema:dry": "MIGRATE_DRY_RUN=1 node server/scripts/runMultiTenancyMigration.mjs",
            "migrate:password-hash": "node --env-file=.env.mysql.local server/scripts/migratePasswordsToBcrypt.mjs"
      }
}
