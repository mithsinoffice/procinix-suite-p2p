  @@unique([tenantId, grnRef])
  @@index([tenantId, poId])
  @@map("goods_receipt_notes")
}

model GoodsReceiptLine {
  id              String            @id @default(uuid())
  grnId           String
  poLineId        String
  itemId          String?
  description     String
  orderedQty      Decimal           @db.Decimal(15,4)
  receivedQty     Decimal           @db.Decimal(15,4)
  acceptedQty     Decimal           @db.Decimal(15,4)
  rejectedQty     Decimal           @db.Decimal(15,4) @default(0)
  rejectionReason String?
  batchNo         String?
  serialNo        String?
  expiryDate      DateTime?         @db.Date
  storageLocation String?
  qualityStatus   String            @default("PENDING")
  grn             GoodsReceiptNote  @relation(fields: [grnId], references: [id], onDelete: Cascade)
  poLine          PurchaseOrderLine @relation(fields: [poLineId], references: [id])
  @@map("goods_receipt_lines")
}

// ── SRN ───────────────────────────────────────────────────────────────────────
model SupplierReturnNote {
  id                 String   @id @default(uuid())
  tenantId           String
  srnRef             String
  srnDate            DateTime @db.Date
  grnId              String
  vendorId           String
  returnReason       String?
  creditNoteRef      String?
  workflowInstanceId String?
  status             String   @default("DRAFT")
  createdByUserId    String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  lines              SupplierReturnLine[]
  @@unique([tenantId, srnRef])
  @@map("supplier_return_notes")
}

model SupplierReturnLine {
  id             String             @id @default(uuid())
  srnId          String
  grnLineId      String
  itemId         String?
  description    String
  returnQty      Decimal            @db.Decimal(15,4)
  returnReason   String
  reverseGst     Boolean            @default(true)
  reverseTds     Boolean            @default(false)
  srn            SupplierReturnNote @relation(fields: [srnId], references: [id], onDelete: Cascade)
  @@map("supplier_return_lines")
}

// ── VENDOR ADVANCE ────────────────────────────────────────────────────────────
model VendorAdvance {
  id                 String   @id @default(uuid())
  tenantId           String
  advanceRef         String
  vendorId           String
  entityId           String
  poId               String?
  milestoneId        String?
  advanceAmount      Decimal  @db.Decimal(15,2)
  currencyCode       String   @default("INR")
  advanceDate        DateTime @db.Date
  purpose            String?
  glCodeId           String?
  tdsApplicable      Boolean  @default(false)
  tdsSectionId       String?
  tdsAmount          Decimal  @db.Decimal(15,2) @default(0)
  adjustedAmount     Decimal  @db.Decimal(15,2) @default(0)
  pendingAmount      Decimal  @db.Decimal(15,2) @default(0)
  workflowInstanceId String?
  status             String   @default("DRAFT")
  paidAt             DateTime?
  createdByUserId    String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  adjustments        VendorAdvanceAdjustment[]
  po                 PurchaseOrder? @relation(fields: [poId], references: [id])
  @@unique([tenantId, advanceRef])
  @@index([tenantId, vendorId, status])
  @@map("vendor_advances")
}

model VendorAdvanceAdjustment {
  id             String        @id @default(uuid())
  advanceId      String
  invoiceId      String
  adjustedAmount Decimal       @db.Decimal(15,2)
  adjustmentDate DateTime      @db.Date
  tdsCredit      Decimal       @db.Decimal(15,2) @default(0)
  advance        VendorAdvance @relation(fields: [advanceId], references: [id])
  @@map("vendor_advance_adjustments")
}
