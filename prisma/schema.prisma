generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id             String          @id @default(uuid())
  code           String          @unique
  name           String
  gstin          String?
  pan            String?
  plan           String          @default("TRIAL")
  trialExpiresAt DateTime?
  maxEntities    Int             @default(1)
  maxUsers       Int             @default(5)
  maxStorageMb   Int             @default(5120)
  isActive       Boolean         @default(true)
  status         String          @default("ACTIVE")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  users          User[]
  vendors        Vendor[]
  invoices       Invoice[]
  payments       Payment[]
  modules        TenantModule[]
  features       TenantFeature[]
  provisionSchedules     ProvisionSchedule[]
  amortizationSchedules  AmortizationSchedule[]

  @@map("tenants")
}

model User {
  id                 String             @id @default(uuid())
  tenantId           String
  email              String
  passwordHash       String
  name               String
  mobile             String?
  role               UserRole           @default(USER)
  additionalRoles    Json?
  departmentId       String?
  employeeId         String?
  profilePhoto       String?
  mustResetPassword  Boolean            @default(true)
  emailNotifications Boolean            @default(true)
  inAppNotifications Boolean            @default(true)
  dailyDigest        Boolean            @default(false)
  isActive           Boolean            @default(true)
  status             String             @default("ACTIVE")
  lastLoginAt        DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  tenant             Tenant             @relation(fields: [tenantId], references: [id])
  entityAccess       UserEntityAccess[]
  entityRoles        UserEntityRole[]

  @@unique([tenantId, email])
  @@index([tenantId, isActive])
  @@index([tenantId, status])
  @@map("users")
}

enum UserRole {
  SUPER_ADMIN
  TENANT_ADMIN
  ADMIN
  AP_MANAGER
  APPROVER_L1
  APPROVER_L2
  APPROVER_L3
  AP_CLERK
  CFO
  MD
  FINANCE_MANAGER
  PROCUREMENT_HEAD
  DEPT_HEAD
  USER
  VIEWER
}

model UserEntityAccess {
  id               String   @id @default(uuid())
  userId           String
  entityId         String
  roleOverride     String?
  canApprove       Boolean  @default(false)
  approvalLimit    Decimal? @db.Decimal(15, 2)
  canCreatePO      Boolean  @default(false)
  canCreateInvoice Boolean  @default(true)
  canViewOnly      Boolean  @default(false)
  isActive         Boolean  @default(true)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, entityId])
  @@map("user_entity_access")
}

model RolePrivilege {
  id          String   @id @default(uuid())
  tenantId    String
  roleCode    String
  roleName    String
  description String?
  permissions Json
  isSystem    Boolean  @default(false)
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, roleCode])
  @@map("role_privileges")
}

model UserEntityRole {
  id       String  @id @default(uuid())
  userId   String
  entityId String
  roleCode String
  isActive Boolean @default(true)
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, entityId, roleCode])
  @@map("user_entity_roles")
}

model Vendor {
  id                    String                  @id @default(uuid())
  tenantId              String
  vendorCode            String
  legalName             String
  tradeName             String?
  gstin                 String?
  pan                   String
  vendorType            VendorType              @default(SUPPLIER)
  email                 String?
  mobile                String?
  city                  String?
  state                 String?
  pincode               String?
  bankAccountNo         String?
  ifscCode              String?
  bankName              String?
  paymentTerms          Int                     @default(30)
  tdsApplicable         Boolean                 @default(false)
  tdsSectionCode        String?
  panCompliance         PanCompliance           @default(COMPLIANT)
  status                VendorStatus            @default(ACTIVE)
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  tenant                Tenant                  @relation(fields: [tenantId], references: [id])
  invoices              Invoice[]
  cin                   String?
  kycCinStatus          String?
  kycCinCompanyName     String?
  kycCinDateOfReg       String?
  udyamNumber           String?
  // MSME compliance flag — when true, invoices for this vendor inherit the
  // 45-day statutory payment deadline (msmePaymentDue) and surface on the
  // "MSME at risk" tab of the payment queue. Existing udyamNumber + kyc*
  // fields above carry the registration details.
  msmeRegistered        Boolean                 @default(false)
  kycMsmeStatus         String?
  kycMsmeCategory       String?
  kycMsmeRegisteredAt   String?
  panEntityType         String?
  aadharNo              String?
  aadharPanLinked       String?
  msmeCategory          String?
  llpRegNo              String?
  trustRegNo            String?
  kycPanStatus          String?
  kycPanName            String?
  kycGstStatus          String?
  kycGstName            String?
  kycBankStatus         String?
  kycBankAccountName    String?
  kycBankNameMatchScore Int?
  kycBankNameMatch      Boolean?
  kycBankNameMatchedAt  DateTime?
  kycLastCheckedAt      DateTime?
  gstComplianceScore    Int?
  einvoiceRequired      Boolean                 @default(false)
  itcRisk               String?
  is206ABApplicable     Boolean                 @default(false)
  section206ABRate      Decimal?                @db.Decimal(5, 2)
  section206ABReason    String?
  lastItrFiledYear      String?
  section206ABCheckedAt DateTime?
  gstr1LastFiledPeriod  String?
  gstr1LastFiledDate    String?
  gstr3bLastFiledPeriod String?
  gstr3bLastFiledDate   String?
  gstReturnRisk         String?
  gstReturnCheckedAt    DateTime?
  complianceCheckedAt   DateTime?
  transbnkBeneficiaryId String?
  transbnkRegisteredAt  DateTime?
  // Extended classification
  vendorCategoryId      String?
  vendorGroupId         String?
  countryCode           String                  @default("IN")
  taxRegimeCode         String?
  tan                   String?
  // TDS extensions
  tdsSectionId          String?
  tdsRate               Decimal?                @db.Decimal(5, 2)
  tdsExempt             Boolean                 @default(false)
  lowerTdsCertNo        String?
  lowerTdsSection       String?
  lowerTdsRate          Decimal?                @db.Decimal(5, 2)
  lowerTdsValidFrom     DateTime?
  lowerTdsValidTo       DateTime?
  lowerTdsAlertDays     Int                     @default(30)
  // International tax
  vatNumber             String?
  whtRegistration       String?
  localTaxId            String?
  // Address
  addressLine1          String?
  addressLine2          String?
  stateCode             String?
  contactName           String?
  website               String?
  // Payment
  paymentCurrency       String                  @default("INR")
  paymentMode           String                  @default("NEFT")
  // ERP sync
  erpVendorCode         String?
  erpSystem             String?
  erpSyncStatus         String?
  erpSyncedAt           DateTime?
  erpSyncError          String?
  invitationId          String?
  kycLastRunAt          DateTime?
  // Sub-table relations
  gstRegistrations      VendorGstRegistration[]
  bankAccounts          VendorBankAccount[]
  entityMappings        VendorEntityMapping[]
  documents             VendorDocument[]

  @@unique([tenantId, gstin])
  @@unique([tenantId, vendorCode])
  @@index([tenantId, status, createdAt(sort: Desc)])
  @@map("vendors")
}

enum VendorType {
  SUPPLIER
  SERVICE_PROVIDER
  CONTRACTOR
  EMPLOYEE
  INTERCOMPANY
}

enum VendorStatus {
  DRAFT
  ACTIVE
  INACTIVE
  BLOCKED
  PENDING_APPROVAL
  REJECTED
}

enum PanCompliance {
  COMPLIANT
  NON_FILER
  LOWER_DEDUCTION
  EXEMPTED
}

model Department {
  id               String    @id @default(uuid())
  tenantId         String
  code             String
  name             String
  isActive         Boolean   @default(true)
  status           String    @default("ACTIVE")
  createdByUserId  String?
  approvedByUserId String?
  approvedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @default(now()) @updatedAt

  @@unique([tenantId, code])
  @@map("departments")
}

model GlCode {
  id               String    @id @default(uuid())
  tenantId         String
  code             String
  name             String
  accountType      String
  isActive         Boolean   @default(true)
  status           String    @default("ACTIVE")
  createdByUserId  String?
  approvedByUserId String?
  approvedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @default(now()) @updatedAt

  @@unique([tenantId, code])
  @@map("gl_codes")
}

model CostCentre {
  id               String    @id @default(uuid())
  tenantId         String
  code             String
  name             String
  isActive         Boolean   @default(true)
  status           String    @default("ACTIVE")
  createdByUserId  String?
  approvedByUserId String?
  approvedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @default(now()) @updatedAt

  @@unique([tenantId, code])
  @@map("cost_centres")
}

model TaxCode {
  id               String    @id @default(uuid())
  tenantId         String
  code             String
  description      String
  cgstRate         Decimal   @db.Decimal(5, 2)
  sgstRate         Decimal   @db.Decimal(5, 2)
  igstRate         Decimal   @db.Decimal(5, 2)
  isActive         Boolean   @default(true)
  status           String    @default("ACTIVE")
  createdByUserId  String?
  approvedByUserId String?
  approvedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @default(now()) @updatedAt

  @@unique([tenantId, code])
  @@map("tax_codes")
}

model Invoice {
  id                 String            @id @default(uuid())
  tenantId           String
  invoiceNumber      String
  invoiceRef         String?
  invoiceDate        DateTime          @db.Date
  dueDate            DateTime?         @db.Date
  vendorId           String?
  vendorGSTIN        String?
  vendorPAN          String?
  entityId           String?
  billToLocationId   String?
  channelType        String            @default("MANUAL_UPLOAD")
  status             String            @default("DRAFT")
  apLane             String?
  matchScore         Int?
  matchLane          String?
  isPOInvoice        Boolean           @default(false)
  poRef              String?
  grnRef             String?
  subtotal           Decimal           @default(0) @db.Decimal(15, 2)
  discountAmount     Decimal           @default(0) @db.Decimal(15, 2)
  taxableAmount      Decimal           @default(0) @db.Decimal(15, 2)
  cgstAmount         Decimal           @default(0) @db.Decimal(15, 2)
  sgstAmount         Decimal           @default(0) @db.Decimal(15, 2)
  igstAmount         Decimal           @default(0) @db.Decimal(15, 2)
  tdsAmount          Decimal           @default(0) @db.Decimal(15, 2)
  totalAmount        Decimal           @default(0) @db.Decimal(15, 2)
  netPayable         Decimal           @default(0) @db.Decimal(15, 2)
  currencyCode       String            @default("INR")
  exchangeRate       Decimal?          @db.Decimal(18, 8)
  irnNumber          String?
  irnVerified        Boolean           @default(false)
  ocrConfidence      Int?
  ocrRawData         Json?
  // LLM scoring (async, populated by invoice-scorer.service after n8n ingest)
  ocrConfidenceMap      Json?            // per-field 0–1 confidence map
  validationIssues      Json?            // [{ field, severity, message }]
  reviewFlags           Json?            // [{ flag, reason, severity }]
  vendorMatchSuggestion Json?            // { suggestedName, gstin, confidence }
  recommendedAction     String?          @default("needs_review")
                                         // 'auto_process' | 'needs_review' | 'hold'
  llmScoredAt           DateTime?
  // Fuzzy duplicate detection (populated by duplicate-detector.service after
  // ingestion / manual upload / vendor portal). duplicateFlag holds the
  // highest-confidence matchType: EXACT | FUZZY_NUMBER | FUZZY_AMOUNT |
  // FUZZY_VENDOR_DATE | LINE_ITEM. duplicateMatches stores the full match list
  // for the form banner + listing badge to surface.
  duplicateFlag         String?
  duplicateMatches      Json?
  fileUrl            String?           @db.Text
  fileName           String?
  mimeType           String?
  notes              String?           @db.Text
  narration          String?           @db.Text
  periodFrom         DateTime?         @db.Date
  periodTo           DateTime?         @db.Date
  // How the vendor was resolved by the match agent:
  // 'gstin_lookup' | 'fuzzy_name' | 'email_domain' | 'manual' | null
  vendorMatchMethod  String?
  retentionRequired  Boolean           @default(false)
  retentionAmount    Decimal?          @db.Decimal(15, 2)
  retentionGlCodeId  String?
  departmentId       String?
  rejectionReason    String?
  workflowInstanceId String?
  createdByUserId    String
  approvedByUserId   String?
  approvedAt         DateTime?
  paidAt             DateTime?
  // Payment tracking — populated by the payment module on batch execution.
  // paymentStatus drives filtering in the payment queue (UNPAID / PARTIALLY_PAID
  // hide once PAID). paidAmount accumulates across multiple batch lines for
  // partial-payment scenarios.
  paidAmount         Decimal           @default(0) @db.Decimal(15, 2)
  paymentStatus      String            @default("UNPAID")
                                       // UNPAID | PARTIALLY_PAID | PAID
  // MSME compliance — populated when vendor.msmeRegistered=true.
  // msmePaymentDue = invoiceDate + min(45, vendor.paymentTerms) days.
  // msmeBreach + msmeInterest get set by the daily refresh job when overdue.
  msmePaymentDue     DateTime?         @db.Date
  msmeDaysRemaining  Int?
  msmeBreach         Boolean           @default(false)
  msmeInterest       Decimal?          @db.Decimal(15, 2)
  isUrgent           Boolean           @default(false)
  urgentReason       String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  matchType          String? // '2way' | '3way' — set when isPOInvoice = true
  costCentreId       String? // direct-invoice cost allocation
  glCodeId           String? // direct-invoice GL allocation
  tenant             Tenant            @relation(fields: [tenantId], references: [id])
  vendor             Vendor?           @relation(fields: [vendorId], references: [id])
  lines              InvoiceLine[]
  auditLogs          InvoiceAuditLog[]
  approvals          ApprovalStep[]
  poLinks            InvoicePOLink[]

  @@unique([tenantId, invoiceNumber, vendorId])
  @@index([tenantId, status])
  @@index([tenantId, vendorId])
  @@map("invoices")
}

model InvoiceLine {
  id             String   @id @default(uuid())
  invoiceId      String
  lineNumber     Int
  itemId         String?
  itemCode       String?
  description    String
  quantity       Decimal  @db.Decimal(15, 4)
  uom            String?
  unitPrice      Decimal  @db.Decimal(15, 4)
  discountPct    Decimal? @db.Decimal(5, 2)
  discountAmount Decimal  @default(0) @db.Decimal(15, 2)
  taxableAmount  Decimal  @default(0) @db.Decimal(15, 2)
  gstRate        Decimal? @db.Decimal(5, 2)
  cgstAmount     Decimal  @default(0) @db.Decimal(15, 2)
  sgstAmount     Decimal  @default(0) @db.Decimal(15, 2)
  igstAmount     Decimal  @default(0) @db.Decimal(15, 2)
  tdsRate        Decimal? @db.Decimal(5, 2)
  tdsAmount      Decimal  @default(0) @db.Decimal(15, 2)
  rcmApplicable  Boolean  @default(false)
  hsnCode        String?
  sacCode        String?
  glCodeId       String?
  costCentreId   String?
  profitCentreId String?
  lineTotal      Decimal  @default(0) @db.Decimal(15, 2)
  invoice        Invoice     @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  item           ItemMaster? @relation(fields: [itemId], references: [id])

  @@index([invoiceId])
  @@map("invoice_lines")
}

model InvoiceAuditLog {
  id        String   @id @default(uuid())
  invoiceId String
  tenantId  String
  action    String
  userId    String?
  userName  String?
  details   Json?
  createdAt DateTime @default(now())
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_audit_logs")
}

model Payment {
  id                    String        @id @default(uuid())
  tenantId              String
  paymentRef            String
  invoiceId             String
  vendorId              String
  amount                Decimal       @db.Decimal(15, 2)
  currency              String        @default("INR")
  paymentDate           DateTime?     @db.Date
  paymentMode           PaymentMode   @default(NEFT)
  bankRefNumber         String?
  status                PaymentStatus @default(PENDING)
  narration             String?
  createdByUserId       String
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  tenant                Tenant        @relation(fields: [tenantId], references: [id])
  transbnkTransactionId String?
  transbnkUtr           String?
  transbnkRawStatus     String?
  transbnkInitiatedAt   DateTime?
  transbnkCompletedAt   DateTime?
  transbnkFailureReason String?

  @@unique([tenantId, paymentRef])
  @@index([tenantId, status, createdAt(sort: Desc)])
  @@index([tenantId, vendorId])
  @@map("payments")
}

enum PaymentMode {
  NEFT
  RTGS
  IMPS
  CHEQUE
  CASH
  UPI
  WIRE
}

enum PaymentStatus {
  PENDING
  APPROVED
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
  REVERSED
}

model WorkflowInstance {
  id                String                  @id @default(uuid())
  tenantId          String
  definitionId      String?
  entityType        String
  entityId          String
  status            String                  @default("IN_PROGRESS")
  currentStageOrder Int                     @default(1)
  onHoldReason      String?
  onHoldBy          String?
  onHoldAt          DateTime?
  releasedBy        String?
  releasedAt        DateTime?
  releaseRemarks    String?
  startedAt         DateTime                @default(now())
  completedAt       DateTime?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  definition        WorkflowDefinition?     @relation(fields: [definitionId], references: [id])
  stages            WorkflowInstanceStage[]
  chats             WorkflowChat[]

  @@index([tenantId, entityType, entityId])
  @@index([tenantId, status])
  @@map("workflow_instances")
}

model ApprovalStep {
  id                 String         @id @default(uuid())
  workflowInstanceId String?
  invoiceId          String?
  tenantId           String
  level              Int
  approverId         String
  status             ApprovalStatus @default(PENDING)
  comments           String?        @db.Text
  actionAt           DateTime?
  delegatedTo        String?
  createdAt          DateTime       @default(now())
  invoice            Invoice?       @relation(fields: [invoiceId], references: [id])

  @@index([tenantId, status])
  @@index([approverId, status])
  @@map("approval_steps")
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  DELEGATED
  ESCALATED
}

model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String
  userId     String
  action     String
  entityType String
  entityId   String
  before     Json?
  after      Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([tenantId, entityType, entityId])
  @@index([tenantId, createdAt(sort: Desc)])
  @@map("audit_logs")
}

model InvoiceIngestionJob {
  id            String   @id @default(uuid())
  tenantId      String
  channelType   String
  status        String   @default("QUEUED")
  rawFileUrl    String?  @db.Text
  rawFileBase64 String?  @db.LongText
  fileName      String?
  mimeType      String?
  emailFrom     String?
  emailSubject  String?
  extractedData Json?
  errorMessage  String?  @db.Text
  invoiceId     String?
  ocrJobId      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, channelType])
  @@map("invoice_ingestion_jobs")
}

model InvoiceMatchScore {
  id                  String   @id @default(uuid())
  invoiceId           String   @unique
  tenantId            String
  vendorScore         Int      @default(0)
  poScore             Int      @default(0)
  amountScore         Int      @default(0)
  grnScore            Int      @default(0)
  gstScore            Int      @default(0)
  ocrScore            Int      @default(0)
  totalScore          Int      @default(0)
  lane                String
  isPOInvoice         Boolean  @default(false)
  guardrailsTriggered Json?
  scoreBreakdown      Json?
  createdAt           DateTime @default(now())

  @@index([tenantId])
  @@map("invoice_match_scores")
}

model Country {
  id              String   @id @default(uuid())
  code            String   @unique
  name            String
  isoCode3        String?
  localName       String?
  region          String?
  dialCode        String?
  currency        String?
  isActive        Boolean  @default(true)
  status          String   @default("ACTIVE")
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt

  @@map("countries")
}

model State {
  id              String   @id @default(uuid())
  code            String
  name            String
  countryCode     String   @default("IN")
  gstCode         String?
  isActive        Boolean  @default(true)
  status          String   @default("ACTIVE")
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt

  @@unique([code, countryCode])
  @@map("states")
}

model City {
  id              String   @id @default(uuid())
  name            String
  stateCode       String
  countryCode     String?
  timezone        String?
  isCapital       Boolean  @default(false)
  isMetro         Boolean  @default(false)
  isActive        Boolean  @default(true)
  status          String   @default("ACTIVE")
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([name, stateCode])
  @@map("cities")
}

model FxRate {
  id              String    @id @default(uuid())
  fromCurrency    String
  toCurrency      String
  rate            Decimal   @db.Decimal(18, 8)
  effectiveDate   DateTime  @db.Date
  expiryDate      DateTime? @db.Date
  source          String    @default("MANUAL")
  isActive        Boolean   @default(true)
  status          String    @default("ACTIVE")
  createdByUserId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([fromCurrency, toCurrency, effectiveDate])
  @@map("fx_rates")
}

model Designation {
  id               String    @id @default(uuid())
  tenantId         String
  code             String
  name             String
  level            Int?
  isActive         Boolean   @default(true)
  status           String    @default("ACTIVE")
  createdByUserId  String?
  approvedByUserId String?
  approvedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([tenantId, code])
  @@map("designations")
}

model Entity {
  id                String         @id @default(uuid())
  tenantId          String
  code              String
  name              String
  shortName         String?
  entityType        String?        @default("SUBSIDIARY")
  cinNumber         String?
  incorporationDate DateTime?      @db.Date
  website           String?
  phone             String?
  gstin             String?
  pan               String?
  tan               String?
  addressLine1      String?
  city              String?
  state             String?
  pincode           String?
  countryCode       String         @default("IN")
  taxRegimeId       String?
  vatNumber         String?
  taxRegime         TaxRegime?     @relation(fields: [taxRegimeId], references: [id])
  logoUrl           String?
  baseCurrencyCode  String?        @default("INR")
  currentFyId       String?
  currentFy         FinancialYear? @relation(fields: [currentFyId], references: [id])
  isActive          Boolean        @default(true)
  status            String         @default("ACTIVE")
  createdByUserId   String?
  approvedByUserId  String?
  approvedAt        DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@unique([tenantId, code])
  @@map("entities")
}

model Location {
  id               String    @id @default(uuid())
  tenantId         String
  code             String
  name             String
  entityId         String?
  addressLine1     String?
  city             String?
  state            String?
  pincode          String?
  locationType     String?
  spocName         String?
  spocEmail        String?
  spocMobile       String?
  spocDescription  String?
  isActive         Boolean   @default(true)
  status           String    @default("ACTIVE")
  createdByUserId  String?
  approvedByUserId String?
  approvedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([tenantId, code])
