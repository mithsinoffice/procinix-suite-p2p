  grnQty             Decimal            @default(0) @db.Decimal(15, 4)
  pendingQty         Decimal            @default(0) @db.Decimal(15, 4)
  invoicedQty        Decimal            @default(0) @db.Decimal(15, 4)
  rateContractLineId String?
  po                 PurchaseOrder      @relation(fields: [poId], references: [id], onDelete: Cascade)
  grnLines           GoodsReceiptLine[]

  @@map("purchase_order_lines")
}

model POPaymentMilestone {
