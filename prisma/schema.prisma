generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String    @id @default(uuid())
  code      String    @unique
  name      String
  gstin     String?
  pan       String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  users     User[]
  vendors   Vendor[]
  invoices  Invoice[]
  payments  Payment[]
  @@map("tenants")
}

model User {
  id           String    @id @default(uuid())
  tenantId     String
  email        String
  passwordHash String
  name         String
  role         UserRole  @default(USER)
  departmentId String?
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  tenant       Tenant    @relation(fields: [tenantId], references: [id])
  @@unique([tenantId, email])
  @@index([tenantId, isActive])
  @@map("users")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  APPROVER_L1
  APPROVER_L2
  APPROVER_L3
  AP_CLERK
  USER
  VIEWER
}

model Vendor {
  id             String        @id @default(uuid())
  tenantId       String
  vendorCode     String
  legalName      String
  tradeName      String?
  gstin          String?
  pan            String
  vendorType     VendorType    @default(SUPPLIER)
  email          String?
  mobile         String?
  city           String?
  state          String?
  pincode        String?
  bankAccountNo  String?
  ifscCode       String?
  bankName       String?
  paymentTerms   Int           @default(30)
  tdsApplicable  Boolean       @default(false)
  tdsSectionCode String?
  panCompliance  PanCompliance @default(COMPLIANT)
  status         VendorStatus  @default(ACTIVE)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  tenant         Tenant        @relation(fields: [tenantId], references: [id])
  invoices       Invoice[]
  cin                   String?
  kycCinStatus          String?
  kycCinCompanyName     String?
  kycCinDateOfReg       String?
  udyamNumber           String?
  kycMsmeStatus         String?
  kycMsmeCategory       String?
  kycMsmeRegisteredAt   String?
  kycPanStatus          String?
  kycPanName            String?
  kycGstStatus          String?
  kycGstName            String?
  kycBankStatus         String?
  kycBankAccountName    String?
  kycBankNameMatchScore Int?
  kycBankNameMatch      Boolean?
  kycBankNameMatchedAt  DateTime?
  kycLastCheckedAt      DateTime?
  gstComplianceScore    Int?
  einvoiceRequired      Boolean   @default(false)
  itcRisk               String?
  is206ABApplicable     Boolean   @default(false)
  section206ABRate      Decimal?  @db.Decimal(5, 2)
  section206ABReason    String?
  lastItrFiledYear      String?
  section206ABCheckedAt DateTime?
  gstr1LastFiledPeriod  String?
  gstr1LastFiledDate    String?
  gstr3bLastFiledPeriod String?
  gstr3bLastFiledDate   String?
  gstReturnRisk         String?
  gstReturnCheckedAt    DateTime?
  complianceCheckedAt   DateTime?
  transbnkBeneficiaryId String?
  transbnkRegisteredAt  DateTime?
  @@unique([tenantId, gstin])
  @@unique([tenantId, vendorCode])
  @@index([tenantId, status, createdAt(sort: Desc)])
  @@map("vendors")
}

enum VendorType {
  SUPPLIER
  SERVICE_PROVIDER
  CONTRACTOR
  EMPLOYEE
  INTERCOMPANY
}

enum VendorStatus {
  ACTIVE
  INACTIVE
  BLOCKED
  PENDING_APPROVAL
}

enum PanCompliance {
  COMPLIANT
  NON_FILER
  LOWER_DEDUCTION
  EXEMPTED
}

model Department {
  id               String    @id @default(uuid())
  tenantId         String
  code             String
  name             String
  isActive         Boolean   @default(true)
  status           String    @default("ACTIVE")
  createdByUserId  String?
  approvedByUserId String?
  approvedAt       DateTime?
  @@unique([tenantId, code])
  @@map("departments")
}

model GlCode {
  id               String    @id @default(uuid())
  tenantId         String
  code             String
  name             String
  accountType      String
  isActive         Boolean   @default(true)
  status           String    @default("ACTIVE")
  createdByUserId  String?
  approvedByUserId String?
  approvedAt       DateTime?
  @@unique([tenantId, code])
  @@map("gl_codes")
}

model CostCentre {
  id               String    @id @default(uuid())
  tenantId         String
  code             String
  name             String
  isActive         Boolean   @default(true)
  status           String    @default("ACTIVE")
  createdByUserId  String?
  approvedByUserId String?
  approvedAt       DateTime?
  @@unique([tenantId, code])
  @@map("cost_centres")
}

model TaxCode {
  id               String    @id @default(uuid())
  tenantId         String
  code             String
  description      String
  cgstRate         Decimal   @db.Decimal(5, 2)
  sgstRate         Decimal   @db.Decimal(5, 2)
  igstRate         Decimal   @db.Decimal(5, 2)
  isActive         Boolean   @default(true)
  status           String    @default("ACTIVE")
  createdByUserId  String?
  approvedByUserId String?
  approvedAt       DateTime?
  @@unique([tenantId, code])
  @@map("tax_codes")
}

model Invoice {
  id                 String        @id @default(uuid())
  tenantId           String
  invoiceNumber      String
  vendorId           String
  invoiceDate        DateTime      @db.Date
  dueDate            DateTime?     @db.Date
  currency           String        @default("INR")
  subtotal           Decimal       @db.Decimal(15, 2)
  taxAmount          Decimal       @db.Decimal(15, 2) @default(0)
  tdsAmount          Decimal       @db.Decimal(15, 2) @default(0)
  totalAmount        Decimal       @db.Decimal(15, 2)
  netPayable         Decimal       @db.Decimal(15, 2)
  poId               String?
  grnId              String?
  glCodeId           String?
  costCentreId       String?
  departmentId       String?
  narration          String?       @db.Text
  attachmentUrls     Json?
  ocrRawData         Json?
  matchStatus        MatchStatus   @default(UNMATCHED)
  status             InvoiceStatus @default(DRAFT)
  approvalLane       ApprovalLane  @default(MANUAL)
  workflowInstanceId String?
  createdByUserId    String
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  tenant             Tenant        @relation(fields: [tenantId], references: [id])
  vendor             Vendor        @relation(fields: [vendorId], references: [id])
  lines              InvoiceLine[]
  approvals          ApprovalStep[]
  channelType        String    @default("MANUAL_UPLOAD")
  matchScore         Int?
  matchLane          String?
  ingestionJobId     String?
  ocrConfidence      Int?
  irn                String?
  isEInvoice         Boolean   @default(false)
  @@unique([tenantId, vendorId, invoiceNumber])
  @@index([tenantId, status, createdAt(sort: Desc)])
  @@index([tenantId, vendorId])
  @@index([tenantId, dueDate])
  @@map("invoices")
}

model InvoiceLine {
  id           String  @id @default(uuid())
  invoiceId    String
  lineNumber   Int
  description  String
  quantity     Decimal @db.Decimal(12, 3)
  unitPrice    Decimal @db.Decimal(15, 2)
  amount       Decimal @db.Decimal(15, 2)
  taxCodeId    String?
  cgst         Decimal @db.Decimal(15, 2) @default(0)
  sgst         Decimal @db.Decimal(15, 2) @default(0)
  igst         Decimal @db.Decimal(15, 2) @default(0)
  tdsAmount    Decimal @db.Decimal(15, 2) @default(0)
  isRcm        Boolean @default(false)
  glCodeId     String?
  costCentreId String?
  invoice      Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  @@index([invoiceId])
  @@map("invoice_lines")
}

enum InvoiceStatus {
  DRAFT
  SUBMITTED
  PENDING_L1
  PENDING_L2
  PENDING_L3
  APPROVED
  REJECTED
  ON_HOLD
  PAID
  PARTIALLY_PAID
  CANCELLED
}
enum MatchStatus {
  UNMATCHED
  TWO_WAY_MATCH
  THREE_WAY_MATCH
  EXCEPTION
}

enum ApprovalLane {
  STP
  MANUAL
  REVIEW
}

model Payment {
  id              String        @id @default(uuid())
  tenantId        String
  paymentRef      String
  invoiceId       String
  vendorId        String
  amount          Decimal       @db.Decimal(15, 2)
  currency        String        @default("INR")
  paymentDate     DateTime?     @db.Date
  paymentMode     PaymentMode   @default(NEFT)
  bankRefNumber   String?
  status          PaymentStatus @default(PENDING)
  narration       String?
  createdByUserId String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  tenant          Tenant        @relation(fields: [tenantId], references: [id])
  transbnkTransactionId String?
  transbnkUtr           String?
  transbnkRawStatus     String?
  transbnkInitiatedAt   DateTime?
  transbnkCompletedAt   DateTime?
  transbnkFailureReason String?
  @@unique([tenantId, paymentRef])
  @@index([tenantId, status, createdAt(sort: Desc)])
  @@index([tenantId, vendorId])
  @@map("payments")
}

enum PaymentMode {
  NEFT
  RTGS
  IMPS
  CHEQUE
  CASH
  UPI
  WIRE
}

enum PaymentStatus {
  PENDING
  APPROVED
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
  REVERSED
}

model WorkflowInstance {
  id                String    @id @default(uuid())
  tenantId          String
  definitionId      String?
  entityType        String
  entityId          String
  status            String    @default("IN_PROGRESS")
  currentStageOrder Int       @default(1)
  onHoldReason      String?
  onHoldBy          String?
  onHoldAt          DateTime?
  releasedBy        String?
  releasedAt        DateTime?
  releaseRemarks    String?
  startedAt         DateTime  @default(now())
  completedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  definition        WorkflowDefinition? @relation(fields: [definitionId], references: [id])
  stages            WorkflowInstanceStage[]
  chats             WorkflowChat[]
  @@index([tenantId, entityType, entityId])
  @@index([tenantId, status])
  @@map("workflow_instances")
}

model ApprovalStep {
  id                 String            @id @default(uuid())
  workflowInstanceId String?
  invoiceId          String?
  tenantId           String
  level              Int
  approverId         String
  status             ApprovalStatus    @default(PENDING)
  comments           String?           @db.Text
  actionAt           DateTime?
  delegatedTo        String?
  createdAt          DateTime          @default(now())
  invoice            Invoice?          @relation(fields: [invoiceId], references: [id])
  @@index([tenantId, status])
  @@index([approverId, status])
  @@map("approval_steps")
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  DELEGATED
  ESCALATED
}

model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String
  userId     String
  action     String
  entityType String
  entityId   String
  before     Json?
  after      Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  @@index([tenantId, entityType, entityId])
  @@index([tenantId, createdAt(sort: Desc)])
  @@map("audit_logs")
}

model InvoiceIngestionJob {
  id            String   @id @default(uuid())
  tenantId      String
  channelType   String
  status        String   @default("QUEUED")
  rawFileUrl    String?  @db.Text
  rawFileBase64 String?  @db.LongText
  fileName      String?
  mimeType      String?
  emailFrom     String?
  emailSubject  String?
  extractedData Json?
  errorMessage  String?  @db.Text
  invoiceId     String?
  ocrJobId      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@index([tenantId, status])
  @@index([tenantId, channelType])
  @@map("invoice_ingestion_jobs")
}

model InvoiceMatchScore {
  id                  String   @id @default(uuid())
  invoiceId           String   @unique
  tenantId            String
  vendorScore         Int      @default(0)
  poScore             Int      @default(0)
  amountScore         Int      @default(0)
  grnScore            Int      @default(0)
  gstScore            Int      @default(0)
  ocrScore            Int      @default(0)
  totalScore          Int      @default(0)
  lane                String
  isPOInvoice         Boolean  @default(false)
  guardrailsTriggered Json?
  scoreBreakdown      Json?
  createdAt           DateTime @default(now())
  @@index([tenantId])
  @@map("invoice_match_scores")
}

model Country {
  id              String   @id @default(uuid())
  code            String   @unique
  name            String
  isoCode3        String?
  localName       String?
  region          String?
  dialCode        String?
  currency        String?
  isActive        Boolean  @default(true)
  status          String   @default("ACTIVE")
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt
  @@map("countries")
}

model State {
  id              String   @id @default(uuid())
  code            String
  name            String
  countryCode     String   @default("IN")
  gstCode         String?
  isActive        Boolean  @default(true)
  status          String   @default("ACTIVE")
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt
  @@unique([code, countryCode])
  @@map("states")
}

model City {
  id              String   @id @default(uuid())
  name            String
  stateCode       String
  countryCode     String?
  timezone        String?
  isCapital       Boolean  @default(false)
  isMetro         Boolean  @default(false)
  isActive        Boolean  @default(true)
  status          String   @default("ACTIVE")
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  @@map("cities")
}

model Designation {
  id               String    @id @default(uuid())
  tenantId         String
  code             String
  name             String
  level            Int?
  isActive         Boolean   @default(true)
  status           String    @default("ACTIVE")
  createdByUserId  String?
  approvedByUserId String?
  approvedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  @@unique([tenantId, code])
  @@map("designations")
}

model Entity {
  id                String    @id @default(uuid())
  tenantId          String
  code              String
  name              String
  shortName         String?
  entityType        String?   @default("SUBSIDIARY")
  cinNumber         String?
  incorporationDate DateTime? @db.Date
  website           String?
  phone             String?
  gstin             String?
  pan               String?
  tan               String?
  addressLine1      String?
  city             String?
  state            String?
  pincode          String?
  countryCode      String    @default("IN")
  taxRegimeId      String?
  vatNumber        String?
  taxRegime        TaxRegime? @relation(fields: [taxRegimeId], references: [id])
  logoUrl          String?
  baseCurrencyCode String?   @default("INR")
  currentFyId      String?
  currentFy        FinancialYear? @relation(fields: [currentFyId], references: [id])
  isActive         Boolean   @default(true)
  status           String    @default("ACTIVE")
  createdByUserId  String?
  approvedByUserId String?
  approvedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  @@unique([tenantId, code])
  @@map("entities")
}

model Location {
  id               String    @id @default(uuid())
  tenantId         String
  code             String
  name             String
  entityId         String?
  addressLine1     String?
  city             String?
  state            String?
  pincode          String?
  locationType     String?
  spocName         String?
  spocEmail        String?
  spocMobile       String?
  spocDescription  String?
  isActive         Boolean   @default(true)
  status           String    @default("ACTIVE")
  createdByUserId  String?
  approvedByUserId String?
  approvedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  @@unique([tenantId, code])
  @@map("locations")
}

model Currency {
  id           String  @id @default(uuid())
  code         String  @unique
  name         String
  symbol       String
  exchangeRate Decimal @db.Decimal(12, 6) @default(1)
  isBase       Boolean @default(false)
  isActive     Boolean @default(true)
  @@map("currencies")
}

model FinancialYear {
  id               String    @id @default(uuid())
  tenantId         String
  code             String
  name             String
  startDate        DateTime  @db.Date
  endDate          DateTime  @db.Date
  isCurrent        Boolean   @default(false)
  isActive         Boolean   @default(true)
  status           String    @default("ACTIVE")
  createdByUserId  String?
  approvedByUserId String?
  approvedAt       DateTime?
  entities         Entity[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  @@unique([tenantId, code])
  @@map("financial_years")
}

model HolidayCalendar {
  id               String    @id @default(uuid())
  tenantId         String
  code             String
  name             String
  year             Int
  isActive         Boolean   @default(true)
  status           String    @default("ACTIVE")
  createdByUserId  String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  holidays         Holiday[]
  @@unique([tenantId, code])
  @@map("holiday_calendars")
}

model Holiday {
  id         String          @id @default(uuid())
  calendarId String
  name       String
  date       DateTime        @db.Date
  type       String          @default("PUBLIC")
  calendar   HolidayCalendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)
  @@map("holidays")
}

model TaxRegime {
  id               String    @id @default(uuid())
  tenantId         String
  code             String
  name             String
  description      String?
  isActive         Boolean   @default(true)
  status           String    @default("ACTIVE")
  createdByUserId  String?
  approvedByUserId String?
  approvedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  countryCode      String   @default("IN")
  regimeType       String   @default("GST")
  requiresGstin    Boolean  @default(false)
  requiresVat      Boolean  @default(false)
  requiresPan      Boolean  @default(false)
  tdsApplicable    Boolean  @default(false)
  vatRate          Decimal? @db.Decimal(5, 2)
  withholdingRate  Decimal? @db.Decimal(5, 2)
  currencyCode     String   @default("INR")
  effectiveFrom        DateTime? @db.Date
  effectiveTo          DateTime? @db.Date
  einvoicingRequired   Boolean   @default(false)
  einvoicingProvider   String?
  einvoicingThreshold  Decimal?  @db.Decimal(15, 2)
  einvoicingFormat     String?
  placeOfSupplyRuleSet String?
  kycFieldSchema       Json?
  taxTypes             Json?
  entities         Entity[]
  @@unique([tenantId, code])
  @@map("tax_regimes")
}

model WorkflowRule {
  id               String    @id @default(uuid())
  tenantId         String
  code             String
  name             String
  module           String
  amountFrom       Decimal?  @db.Decimal(15, 2)
  amountTo         Decimal?  @db.Decimal(15, 2)
  levels           Int       @default(1)
  approverL1       String?
  approverL2       String?
  approverL3       String?
  isActive         Boolean   @default(true)
  status           String    @default("ACTIVE")
  createdByUserId  String?
  approvedByUserId String?
  approvedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  @@unique([tenantId, code])
  @@map("workflow_rules")
}

model Employee {
  id               String    @id @default(uuid())
  tenantId         String
  code             String
  name             String
  email            String?
  mobile           String?
  departmentId     String?
  designationId    String?
  locationId       String?
  managerId        String?
  joiningDate      DateTime? @db.Date
  pan              String?
  isActive         Boolean   @default(true)
  status           String    @default("ACTIVE")
  createdByUserId  String?
  approvedByUserId String?
  approvedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  @@unique([tenantId, code])
  @@map("employees")
}

model WorkflowDefinition {
  id              String   @id @default(uuid())
  tenantId        String
  code            String
  name            String
  description     String?
  module          String
  entityId        String?
  departmentId    String?
  priority        Int      @default(0)
  isDefault       Boolean  @default(false)
  isActive        Boolean  @default(true)
  status          String   @default("ACTIVE")
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  stages          WorkflowDefinitionStage[]
  conditions      WorkflowDefinitionCondition[]
  instances       WorkflowInstance[]
  @@unique([tenantId, code])
  @@index([tenantId, module])
  @@map("workflow_definitions")
}

model WorkflowDefinitionStage {
  id               String   @id @default(uuid())
  definitionId     String
  order            Int
  name             String
  approverType     String   @default("ROLE")
  approverRole     String?
  approverUserId   String?
  slaHours         Int?
  escalateToRole   String?
  autoApproveBelow Decimal? @db.Decimal(15, 2)
  allowDelegation  Boolean  @default(false)
  requiresComment  Boolean  @default(false)
  onReject         String   @default("RETURN_TO_DRAFT")
  definition       WorkflowDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  @@index([definitionId])
  @@map("workflow_definition_stages")
}

model WorkflowDefinitionCondition {
  id           String   @id @default(uuid())
  definitionId String
  field        String
  operator     String
  value        String
  logicGroup   String   @default("AND")
  definition   WorkflowDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  @@index([definitionId])
  @@map("workflow_definition_conditions")
}

model WorkflowInstanceStage {
  id            String    @id @default(uuid())
  instanceId    String
  tenantId      String
  stageOrder    Int
  stageName     String
  approverRole  String?
  assignedTo    String?
  status        String    @default("PENDING")
  comments      String?   @db.Text
  actionAt      DateTime?
  actionBy      String?
  slaDeadline   DateTime?
  escalatedAt   DateTime?
  escalatedTo   String?
  delegatedTo   String?
  rejectionMode String?
  instance      WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  @@index([instanceId])
  @@index([tenantId, assignedTo, status])
  @@map("workflow_instance_stages")
}

model WorkflowChat {
  id          String               @id @default(uuid())
  instanceId  String
  tenantId    String
  senderId    String
  senderName  String
  senderRole  String?
  message     String               @db.Text
  messageType String               @default("COMMENT")
  createdAt   DateTime             @default(now())
  attachments WorkflowAttachment[]
  instance    WorkflowInstance     @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  @@index([instanceId])
  @@map("workflow_chats")
}

model WorkflowAttachment {
  id        String       @id @default(uuid())
  chatId    String
  fileName  String
  fileUrl   String       @db.Text
  mimeType  String
  fileSize  Int?
  createdAt DateTime     @default(now())
  chat      WorkflowChat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  @@map("workflow_attachments")
}
