  advances           VendorAdvance[]
  invoiceLinks       InvoicePOLink[]

  @@unique([tenantId, poRef])
  @@index([tenantId, status])
  @@index([tenantId, vendorId])
  @@map("purchase_orders")
}

// Multi-PO-per-invoice link table. One invoice can be split across multiple POs;
// each link carries the portion of the invoice charged to that PO and whether
// the PO is fully consumed by this invoice (closes the PO on approval).
model InvoicePOLink {
  id              String        @id @default(uuid())
  tenantId        String
  invoiceId       String
  poId            String
  invoiceAmount   Decimal       @db.Decimal(15, 2)
  consumptionType String // 'PARTIAL' | 'FULL'
  createdAt       DateTime      @default(now())
  invoice         Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  po              PurchaseOrder @relation(fields: [poId], references: [id])

  @@index([tenantId, invoiceId])
  @@index([tenantId, poId])
  @@map("invoice_po_links")
}

model PurchaseOrderLine {
