// ── ACCOUNTING (provisioning + amortization + GL push) ────────────────────────
// JournalEntry is the canonical record of every GL impact Procinix posts.
// Status lifecycle: POSTED (active) → REVERSED (paired reversal executed) or
// NULLIFIED (invoice arrived and cancelled the provision). reversalSkipped
// marks the paired reversal JV that was short-circuited because the original
// provision was nullified before month-end.
model JournalEntry {
  id                     String    @id @default(uuid())
  tenantId               String
  entryDate              DateTime  @db.Date
  postingDate            DateTime  @db.Date
  period                 String    // "YYYY-MM"
  entryType              String    // PROVISION | PROVISION_REVERSAL | PROVISION_NULLIFIED | ACCRUAL | AMORTIZATION | MANUAL
  status                 String    @default("POSTED") // POSTED | REVERSED | NULLIFIED | SKIP_REVERSAL
  debitGlCode            String
  creditGlCode           String
  amount                 Decimal   @db.Decimal(15, 2)
  currencyCode           String    @default("INR")
  narration              String    @db.Text
  invoiceId              String?
  invoiceLineId          String?
  provisionScheduleId    String?
  amortizationScheduleId String?
  nullifiedByInvoiceId   String?
  reversalOfId           String?
  reversalJvId           String?
  reversalSkipped        Boolean   @default(false)
  erpStatus              String    @default("PENDING") // PENDING | SYNCED | FAILED | SKIPPED | MANUAL_OVERRIDE
  erpRef                 String?
  erpPushedAt            DateTime?
  erpPayload             Json?
  erpResponse            Json?
  retryCount             Int       @default(0)
  lastRetryAt            DateTime?
  createdBy              String
  createdAt              DateTime  @default(now())

  @@index([tenantId, period])
  @@index([tenantId, erpStatus])
  @@index([tenantId, invoiceId])
  @@index([tenantId, entryType])
  @@index([tenantId, provisionScheduleId])
  @@index([tenantId, amortizationScheduleId])
  @@map("journal_entries")
}

model ProvisionSchedule {
  id              String    @id @default(uuid())
  tenantId        String
  itemId          String
  vendorId        String?
  frequency       String    // MONTHLY | QUARTERLY
  amount          Decimal   @db.Decimal(15, 2)
  basis           String    // FIXED_AMOUNT | PERCENTAGE
  status          String    @default("ACTIVE") // ACTIVE | PAUSED | CLOSED
  lastRunDate     DateTime?
  nextRunDate     DateTime?
  expenseGlCode   String
  provisionGlCode String
  createdAt       DateTime  @default(now())
  tenant          Tenant    @relation(fields: [tenantId], references: [id])

  @@index([tenantId, status])
  @@index([tenantId, itemId])
  @@map("provision_schedules")
}

model AmortizationSchedule {
  id            String   @id @default(uuid())
  tenantId      String
  invoiceId     String
  invoiceLineId String?
  totalAmount   Decimal  @db.Decimal(15, 2)
  monthlyAmount Decimal  @db.Decimal(15, 2)
  periodFrom    DateTime @db.Date
  periodTo      DateTime @db.Date
  totalMonths   Int
  basis         String   @default("STRAIGHT_LINE") // STRAIGHT_LINE | DAY_APPORTIONED
  status        String   @default("ACTIVE") // ACTIVE | COMPLETED | CANCELLED
  expenseGlCode String
  prepaidGlCode String
  apGlCode      String
  createdAt     DateTime @default(now())
  tenant        Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId, invoiceId])
  @@index([tenantId, status])
  @@map("amortization_schedules")
}

// ── PAYMENT BATCHES ──────────────────────────────────────────────────────────
// Vendor payments flow through a batch wrapper so a finance manager can sign
// off a single document covering N invoices / advances. Lifecycle:
//   DRAFT → PENDING_APPROVAL → APPROVED → EXECUTED | PARTIALLY_EXECUTED
//                                       ↓
//                                     FAILED
// MSME compliance: containsMsme + msmeVendorCount surface on the listing so
// the AP team can see at-a-glance which batches must go out before the 45-day
// statutory deadline. Urgent batches route to a separate workflow
// (WF-PAYMENT-URGENT, 4h SLA) that bypasses the standard finance review.
model PaymentBatch {
  id                 String   @id @default(uuid())
  tenantId           String
  batchRef           String   // PAY-2026-001
  status             String   @default("DRAFT")
                              // DRAFT | PENDING_APPROVAL | APPROVED |
                              // EXECUTED | PARTIALLY_EXECUTED | FAILED
  isUrgent           Boolean  @default(false)
  urgentReason       String?
  urgentFlaggedBy    String?
  containsMsme       Boolean  @default(false)
  msmeVendorCount    Int      @default(0)
  totalAmount        Decimal  @db.Decimal(15, 2)
  totalTds           Decimal  @db.Decimal(15, 2)
  totalNetPayable    Decimal  @db.Decimal(15, 2)
  paymentDate        DateTime?
  entityId           String
  bankAccountId      String?
  narration          String?  @db.Text
  workflowInstanceId String?
  createdBy          String
  createdAt          DateTime @default(now())
  executedAt         DateTime?
  lines              PaymentBatchLine[]

  @@unique([tenantId, batchRef])
  @@index([tenantId, status])
  @@index([tenantId, entityId])
  @@index([tenantId, isUrgent, status])
  @@map("payment_batches")
}

// One row per invoice or advance being paid. Stores the actual remitted
// amount (which may differ from invoice.netPayable for partial payments),
// the chosen rail (NEFT/RTGS/IMPS/CHEQUE), and the UTR/cheque ref captured
// at execution time. MSME flags are denormalised here so the batch detail
// page renders without a vendor join per row.
model PaymentBatchLine {
  id                String       @id @default(uuid())
  tenantId          String
  batchId           String
  lineType          String       // INVOICE | ADVANCE
  invoiceId         String?
  advanceId         String?
  vendorId          String
  isMsme            Boolean      @default(false)
  msmePaymentDue    DateTime?
  msmeDaysRemaining Int?
  invoiceAmount     Decimal      @db.Decimal(15, 2)
  tdsAmount         Decimal      @db.Decimal(15, 2)
  advanceAdjusted   Decimal      @default(0) @db.Decimal(15, 2)
  paymentAmount     Decimal      @db.Decimal(15, 2)
  paymentType       String       // FULL | PARTIAL
  paymentMethod     String       // NEFT | RTGS | IMPS | CHEQUE
  tdsSection        String?      // 194C / 194J / 194I — drives challan grouping
  utrNumber         String?
  chequeNumber      String?
  chequeDate        DateTime?
  status            String       @default("PENDING")
                                  // PENDING | PAID | FAILED
  failureReason     String?
  paidAt            DateTime?
  batch             PaymentBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@index([tenantId, invoiceId])
  @@index([tenantId, vendorId])
  @@index([tenantId, status])
  @@map("payment_batch_lines")
}

// TDS challan = aggregate TDS withheld in a calendar month, due to government
// by the 7th of the following month. Created/updated automatically when a
// PaymentBatch executes — challans are upserted per (tenant, period, section).
// Once deposited via the bank's TDS portal, the challan number is recorded
// here for compliance reporting (Form 26Q / 27Q quarterly returns).
model TdsChallan {
  id            String    @id @default(uuid())
  tenantId      String
  tdsSection    String    // 194C, 194J etc.
  period        String    // YYYY-MM
  amount        Decimal   @db.Decimal(15, 2)
  dueDate       DateTime  @db.Date
  status        String    @default("PENDING")
                          // PENDING | DEPOSITED | OVERDUE
  challanNumber String?
  depositedAt   DateTime?
  depositedBy   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([tenantId, period, tdsSection])
  @@index([tenantId, status])
  @@index([tenantId, dueDate])
  @@map("tds_challans")
}

// ── PROVISIONS ───────────────────────────────────────────────────────────────
// Provision proposals: month-by-month suggestions generated from item master
// (provisionRequired=true) + any invoices already received for that item in
// the period (mark them invoice-covered so finance doesn't double-book). A
// proposal carries the full GL pair (debit expense / credit provision) so the
// JV post on approval is purely a write, not a re-resolve. ProvisionBatch
// groups N proposals into a single workflow approval — keeps the audit trail
// tight (one approval = one batch JV cluster).
model ProvisionProposal {
  id                 String    @id @default(uuid())
  tenantId           String
  period             String    // "YYYY-MM"
  itemId             String?   // null for manual additions
  vendorId           String?
  description        String    @db.Text
  proposedAmount     Decimal   @db.Decimal(15, 2)
  approvedAmount     Decimal?  @db.Decimal(15, 2)
  isManual           Boolean   @default(false)
  source             String    @default("ITEM_MASTER")
                               // ITEM_MASTER | MANUAL | SYSTEM_SUGGESTION
  expenseGlCode      String
  provisionGlCode    String
  tdsSection         String?
  reversalTrigger    String    @default("FIRST_OF_NEXT_MONTH")
                               // FIRST_OF_NEXT_MONTH | ON_INVOICE_APPROVAL | MANUAL
  narration          String?   @db.Text
  status             String    @default("DRAFT")
                               // DRAFT | SUBMITTED | APPROVED | REJECTED
  workflowInstanceId String?
  // Set when an approved invoice for this item+period already exists — the
  // proposal is then surfaced as "Invoice covered" and no JV gets posted.
  invoiceCoveredId   String?
  batchId            String?
  jvId               String?
  reversalJvId       String?
  createdBy          String
  reviewedBy         String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  approvedAt         DateTime?

  @@index([tenantId, period, status])
  @@index([tenantId, itemId])
  @@index([tenantId, batchId])
  @@map("provision_proposals")
}

model ProvisionBatch {
  id                 String    @id @default(uuid())
  tenantId           String
  period             String    // "YYYY-MM"
  status             String    @default("DRAFT")
                               // DRAFT | SUBMITTED | APPROVED | REJECTED
  totalAmount        Decimal   @db.Decimal(15, 2)
  // MySQL doesn't have a native string-array type — proposalIds is stored as
  // JSON so the engine can serialise/deserialise the membership list without
  // a join table. ProvisionProposal.batchId is the back-pointer for queries.
  proposalIds        Json
  workflowInstanceId String?
  submittedBy        String?
  approvedBy         String?
  createdAt          DateTime  @default(now())
  approvedAt         DateTime?

  @@index([tenantId, period, status])
  @@map("provision_batches")
}
