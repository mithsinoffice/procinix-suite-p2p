// ── PURCHASE ORDER ────────────────────────────────────────────────────────────
model PurchaseOrder {
  id                 String               @id @default(uuid())
  tenantId           String
  poRef              String
  poType             String               @default("STANDARD")
  poDate             DateTime             @db.Date
  poExpiryDate       DateTime?            @db.Date
  autoExpire         Boolean              @default(false)
  vendorId           String
  entityId           String
  shipToLocationId   String?
  billToEntityId     String?
  rateContractId     String?
  blanketPoId        String?
  currencyCode       String               @default("INR")
  exchangeRate       Decimal?             @db.Decimal(18, 8)
  paymentTermsDays   Int                  @default(30)
  paymentMode        String               @default("NEFT")
  deliveryTerms      String?
  warrantyPeriod     String?
  taxType            String               @default("EXCLUSIVE")
  subtotal           Decimal              @default(0) @db.Decimal(15, 2)
  taxAmount          Decimal              @default(0) @db.Decimal(15, 2)
  tdsAmount          Decimal              @default(0) @db.Decimal(15, 2)
  totalAmount        Decimal              @default(0) @db.Decimal(15, 2)
  consumedAmount     Decimal              @default(0) @db.Decimal(15, 2)
  advanceAmount      Decimal              @default(0) @db.Decimal(15, 2)
  advancePct         Decimal?             @db.Decimal(5, 2)
  budgetId           String?
  workflowInstanceId String?
  prRefs             Json?
  notes              String?              @db.Text
  status             String               @default("DRAFT")
  rejectionReason    String?
  sentToVendorAt     DateTime?
  closedAt           DateTime?
  createdByUserId    String?
