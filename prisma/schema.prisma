// ── VENDOR ADVANCE ────────────────────────────────────────────────────────────
model VendorAdvance {
  id                 String                    @id @default(uuid())
  tenantId           String
  advanceRef         String
  vendorId           String
  entityId           String
  poId               String?
  milestoneId        String?
  advanceAmount      Decimal                   @db.Decimal(15, 2)
  currencyCode       String                    @default("INR")
  advanceDate        DateTime                  @db.Date
  purpose            String?
  glCodeId           String?
  tdsApplicable      Boolean                   @default(false)
  tdsSectionId       String?
  tdsAmount          Decimal                   @default(0) @db.Decimal(15, 2)
