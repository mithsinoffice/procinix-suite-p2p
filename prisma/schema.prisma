generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id               String    @id @default(uuid())
  code             String    @unique
  name             String
  gstin            String?
  pan              String?
  plan             String    @default("TRIAL")
  trialExpiresAt   DateTime?
  maxEntities      Int       @default(1)
  maxUsers         Int       @default(5)
  maxStorageMb     Int       @default(5120)
  isActive         Boolean   @default(true)
  status           String    @default("ACTIVE")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  users            User[]
  vendors          Vendor[]
  invoices         Invoice[]
  payments         Payment[]
  modules          TenantModule[]
  features         TenantFeature[]
  @@map("tenants")
}

model User {
  id           String    @id @default(uuid())
  tenantId     String
  email        String
  passwordHash String
  name         String
  role         UserRole  @default(USER)
  departmentId String?
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  tenant       Tenant    @relation(fields: [tenantId], references: [id])
  @@unique([tenantId, email])
  @@index([tenantId, isActive])
  @@map("users")
}

enum UserRole {
  SUPER_ADMIN
  TENANT_ADMIN
  ADMIN
  AP_MANAGER
  APPROVER_L1
  APPROVER_L2
  APPROVER_L3
  AP_CLERK
  CFO
  MD
  USER
  VIEWER
}

model Vendor {
  id             String        @id @default(uuid())
  tenantId       String
  vendorCode     String
  legalName      String
  tradeName      String?
  gstin          String?
  pan            String
  vendorType     VendorType    @default(SUPPLIER)
  email          String?
  mobile         String?
  city           String?
  state          String?
  pincode        String?
  bankAccountNo  String?
  ifscCode       String?
  bankName       String?
  paymentTerms   Int           @default(30)
  tdsApplicable  Boolean       @default(false)
  tdsSectionCode String?
  panCompliance  PanCompliance @default(COMPLIANT)
  status         VendorStatus  @default(ACTIVE)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  tenant         Tenant        @relation(fields: [tenantId], references: [id])
  invoices       Invoice[]
  cin                   String?
  kycCinStatus          String?
  kycCinCompanyName     String?
  kycCinDateOfReg       String?
  udyamNumber           String?
  kycMsmeStatus         String?
  kycMsmeCategory       String?
  kycMsmeRegisteredAt   String?
  panEntityType         String?
  aadharNo              String?
  aadharPanLinked       String?
  msmeCategory          String?
  llpRegNo              String?
  trustRegNo            String?
  kycPanStatus          String?
  kycPanName            String?
  kycGstStatus          String?
  kycGstName            String?
  kycBankStatus         String?
  kycBankAccountName    String?
  kycBankNameMatchScore Int?
  kycBankNameMatch      Boolean?
  kycBankNameMatchedAt  DateTime?
  kycLastCheckedAt      DateTime?
  gstComplianceScore    Int?
  einvoiceRequired      Boolean   @default(false)
  itcRisk               String?
  is206ABApplicable     Boolean   @default(false)
  section206ABRate      Decimal?  @db.Decimal(5, 2)
  section206ABReason    String?
  lastItrFiledYear      String?
  section206ABCheckedAt DateTime?
  gstr1LastFiledPeriod  String?
  gstr1LastFiledDate    String?
  gstr3bLastFiledPeriod String?
  gstr3bLastFiledDate   String?
  gstReturnRisk         String?
  gstReturnCheckedAt    DateTime?
  complianceCheckedAt   DateTime?
  transbnkBeneficiaryId String?
  transbnkRegisteredAt  DateTime?
  // Extended classification
  vendorCategoryId      String?
  vendorGroupId         String?
  countryCode           String    @default("IN")
  taxRegimeCode         String?
  tan                   String?
  // TDS extensions
  tdsSectionId          String?
  tdsRate               Decimal?  @db.Decimal(5, 2)
  tdsExempt             Boolean   @default(false)
  lowerTdsCertNo        String?
  lowerTdsSection       String?
  lowerTdsRate          Decimal?  @db.Decimal(5, 2)
  lowerTdsValidFrom     DateTime?
  lowerTdsValidTo       DateTime?
  lowerTdsAlertDays     Int       @default(30)
  // International tax
  vatNumber             String?
  whtRegistration       String?
  localTaxId            String?
  // Address
  addressLine1          String?
  addressLine2          String?
  stateCode             String?
  contactName           String?
  website               String?
  // Payment
  paymentCurrency       String    @default("INR")
  paymentMode           String    @default("NEFT")
  // ERP sync
  erpVendorCode         String?
  erpSystem             String?
  erpSyncStatus         String?
  erpSyncedAt           DateTime?
  erpSyncError          String?
  invitationId          String?
  kycLastRunAt          DateTime?
  // Sub-table relations
  gstRegistrations      VendorGstRegistration[]
  bankAccounts          VendorBankAccount[]
  entityMappings        VendorEntityMapping[]
  documents             VendorDocument[]
  @@unique([tenantId, gstin])
  @@unique([tenantId, vendorCode])
  @@index([tenantId, status, createdAt(sort: Desc)])
  @@map("vendors")
}

enum VendorType {
  SUPPLIER
  SERVICE_PROVIDER
  CONTRACTOR
  EMPLOYEE
  INTERCOMPANY
}

enum VendorStatus {
  ACTIVE
  INACTIVE
  BLOCKED
  PENDING_APPROVAL
}

enum PanCompliance {
  COMPLIANT
  NON_FILER
  LOWER_DEDUCTION
  EXEMPTED
}

model Department {
  id               String    @id @default(uuid())
  tenantId         String
  code             String
  name             String
  isActive         Boolean   @default(true)
  status           String    @default("ACTIVE")
  createdByUserId  String?
  approvedByUserId String?
  approvedAt       DateTime?
  @@unique([tenantId, code])
  @@map("departments")
}

model GlCode {
  id               String    @id @default(uuid())
  tenantId         String
  code             String
  name             String
  accountType      String
  isActive         Boolean   @default(true)
  status           String    @default("ACTIVE")
  createdByUserId  String?
  approvedByUserId String?
  approvedAt       DateTime?
  @@unique([tenantId, code])
  @@map("gl_codes")
}

model CostCentre {
  id               String    @id @default(uuid())
  tenantId         String
  code             String
  name             String
  isActive         Boolean   @default(true)
  status           String    @default("ACTIVE")
  createdByUserId  String?
  approvedByUserId String?
  approvedAt       DateTime?
  @@unique([tenantId, code])
  @@map("cost_centres")
}

model TaxCode {
  id               String    @id @default(uuid())
  tenantId         String
  code             String
  description      String
  cgstRate         Decimal   @db.Decimal(5, 2)
  sgstRate         Decimal   @db.Decimal(5, 2)
  igstRate         Decimal   @db.Decimal(5, 2)
  isActive         Boolean   @default(true)
  status           String    @default("ACTIVE")
  createdByUserId  String?
  approvedByUserId String?
  approvedAt       DateTime?
  @@unique([tenantId, code])
  @@map("tax_codes")
}

model Invoice {
  id                  String    @id @default(uuid())
  tenantId            String
  invoiceNumber       String
  invoiceRef          String?
  invoiceDate         DateTime  @db.Date
  dueDate             DateTime? @db.Date
  vendorId            String
  entityId            String?
  channelType         String    @default("MANUAL_UPLOAD")
  status              String    @default("DRAFT")
  apLane              String?
  matchScore          Int?
  matchLane           String?
  isPOInvoice         Boolean   @default(false)
  poRef               String?
  grnRef              String?
  subtotal            Decimal   @db.Decimal(15, 2) @default(0)
  discountAmount      Decimal   @db.Decimal(15, 2) @default(0)
  taxableAmount       Decimal   @db.Decimal(15, 2) @default(0)
  cgstAmount          Decimal   @db.Decimal(15, 2) @default(0)
  sgstAmount          Decimal   @db.Decimal(15, 2) @default(0)
  igstAmount          Decimal   @db.Decimal(15, 2) @default(0)
  tdsAmount           Decimal   @db.Decimal(15, 2) @default(0)
  totalAmount         Decimal   @db.Decimal(15, 2) @default(0)
  netPayable          Decimal   @db.Decimal(15, 2) @default(0)
  currencyCode        String    @default("INR")
  exchangeRate        Decimal?  @db.Decimal(18, 8)
  irnNumber           String?
  irnVerified         Boolean   @default(false)
  ocrConfidence       Int?
  ocrRawData          Json?
  fileUrl             String?   @db.Text
  fileName            String?
  mimeType            String?
  notes               String?   @db.Text
  rejectionReason     String?
  workflowInstanceId  String?
  createdByUserId     String
  approvedByUserId    String?
  approvedAt          DateTime?
  paidAt              DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  tenant              Tenant    @relation(fields: [tenantId], references: [id])
  vendor              Vendor    @relation(fields: [vendorId], references: [id])
  lines               InvoiceLine[]
  auditLogs           InvoiceAuditLog[]
  approvals           ApprovalStep[]
  @@unique([tenantId, invoiceNumber, vendorId])
  @@index([tenantId, status])
  @@index([tenantId, vendorId])
  @@map("invoices")
}

model InvoiceLine {
  id             String   @id @default(uuid())
  invoiceId      String
  lineNumber     Int
  itemId         String?
  itemCode       String?
  description    String
  quantity       Decimal  @db.Decimal(15, 4)
  uom            String?
  unitPrice      Decimal  @db.Decimal(15, 4)
  discountPct    Decimal? @db.Decimal(5, 2)
  discountAmount Decimal  @db.Decimal(15, 2) @default(0)
  taxableAmount  Decimal  @db.Decimal(15, 2) @default(0)
  gstRate        Decimal? @db.Decimal(5, 2)
  cgstAmount     Decimal  @db.Decimal(15, 2) @default(0)
  sgstAmount     Decimal  @db.Decimal(15, 2) @default(0)
  igstAmount     Decimal  @db.Decimal(15, 2) @default(0)
  tdsRate        Decimal? @db.Decimal(5, 2)
  tdsAmount      Decimal  @db.Decimal(15, 2) @default(0)
  rcmApplicable  Boolean  @default(false)
  hsnCode        String?
  sacCode        String?
  glCodeId       String?
  costCentreId   String?
  profitCentreId String?
  lineTotal      Decimal  @db.Decimal(15, 2) @default(0)
  invoice        Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  @@index([invoiceId])
  @@map("invoice_lines")
}

model InvoiceAuditLog {
  id        String   @id @default(uuid())
  invoiceId String
  tenantId  String
  action    String
  userId    String?
  userName  String?
  details   Json?
  createdAt DateTime @default(now())
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  @@index([invoiceId])
  @@map("invoice_audit_logs")
}

model Payment {
  id              String        @id @default(uuid())
  tenantId        String
  paymentRef      String
  invoiceId       String
  vendorId        String
  amount          Decimal       @db.Decimal(15, 2)
  currency        String        @default("INR")
  paymentDate     DateTime?     @db.Date
  paymentMode     PaymentMode   @default(NEFT)
  bankRefNumber   String?
  status          PaymentStatus @default(PENDING)
  narration       String?
  createdByUserId String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  tenant          Tenant        @relation(fields: [tenantId], references: [id])
  transbnkTransactionId String?
  transbnkUtr           String?
  transbnkRawStatus     String?
  transbnkInitiatedAt   DateTime?
  transbnkCompletedAt   DateTime?
  transbnkFailureReason String?
  @@unique([tenantId, paymentRef])
  @@index([tenantId, status, createdAt(sort: Desc)])
  @@index([tenantId, vendorId])
  @@map("payments")
}

enum PaymentMode {
  NEFT
  RTGS
  IMPS
  CHEQUE
  CASH
  UPI
  WIRE
}

enum PaymentStatus {
  PENDING
  APPROVED
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
  REVERSED
}

model WorkflowInstance {
  id                String    @id @default(uuid())
  tenantId          String
  definitionId      String?
  entityType        String
  entityId          String
  status            String    @default("IN_PROGRESS")
  currentStageOrder Int       @default(1)
  onHoldReason      String?
  onHoldBy          String?
  onHoldAt          DateTime?
  releasedBy        String?
  releasedAt        DateTime?
  releaseRemarks    String?
  startedAt         DateTime  @default(now())
  completedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  definition        WorkflowDefinition? @relation(fields: [definitionId], references: [id])
  stages            WorkflowInstanceStage[]
  chats             WorkflowChat[]
  @@index([tenantId, entityType, entityId])
  @@index([tenantId, status])
  @@map("workflow_instances")
}

model ApprovalStep {
  id                 String            @id @default(uuid())
  workflowInstanceId String?
  invoiceId          String?
  tenantId           String
  level              Int
  approverId         String
  status             ApprovalStatus    @default(PENDING)
  comments           String?           @db.Text
  actionAt           DateTime?
  delegatedTo        String?
  createdAt          DateTime          @default(now())
  invoice            Invoice?          @relation(fields: [invoiceId], references: [id])
  @@index([tenantId, status])
  @@index([approverId, status])
  @@map("approval_steps")
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  DELEGATED
  ESCALATED
}

model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String
  userId     String
  action     String
  entityType String
  entityId   String
  before     Json?
  after      Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  @@index([tenantId, entityType, entityId])
  @@index([tenantId, createdAt(sort: Desc)])
  @@map("audit_logs")
}

model InvoiceIngestionJob {
  id            String   @id @default(uuid())
  tenantId      String
  channelType   String
  status        String   @default("QUEUED")
  rawFileUrl    String?  @db.Text
  rawFileBase64 String?  @db.LongText
  fileName      String?
  mimeType      String?
  emailFrom     String?
  emailSubject  String?
  extractedData Json?
  errorMessage  String?  @db.Text
  invoiceId     String?
  ocrJobId      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@index([tenantId, status])
  @@index([tenantId, channelType])
  @@map("invoice_ingestion_jobs")
}

model InvoiceMatchScore {
  id                  String   @id @default(uuid())
  invoiceId           String   @unique
  tenantId            String
  vendorScore         Int      @default(0)
  poScore             Int      @default(0)
  amountScore         Int      @default(0)
  grnScore            Int      @default(0)
  gstScore            Int      @default(0)
  ocrScore            Int      @default(0)
  totalScore          Int      @default(0)
  lane                String
  isPOInvoice         Boolean  @default(false)
  guardrailsTriggered Json?
  scoreBreakdown      Json?
  createdAt           DateTime @default(now())
  @@index([tenantId])
  @@map("invoice_match_scores")
}

model Country {
  id              String   @id @default(uuid())
  code            String   @unique
  name            String
  isoCode3        String?
  localName       String?
  region          String?
  dialCode        String?
  currency        String?
  isActive        Boolean  @default(true)
  status          String   @default("ACTIVE")
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt
  @@map("countries")
}

model State {
  id              String   @id @default(uuid())
  code            String
  name            String
  countryCode     String   @default("IN")
  gstCode         String?
  isActive        Boolean  @default(true)
  status          String   @default("ACTIVE")
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt
  @@unique([code, countryCode])
  @@map("states")
}

model City {
  id              String   @id @default(uuid())
  name            String
  stateCode       String
  countryCode     String?
  timezone        String?
  isCapital       Boolean  @default(false)
  isMetro         Boolean  @default(false)
  isActive        Boolean  @default(true)
  status          String   @default("ACTIVE")
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  @@unique([name, stateCode])
  @@map("cities")
}

model FxRate {
  id              String    @id @default(uuid())
  fromCurrency    String
  toCurrency      String
  rate            Decimal   @db.Decimal(18, 8)
  effectiveDate   DateTime  @db.Date
  expiryDate      DateTime? @db.Date
  source          String    @default("MANUAL")
  isActive        Boolean   @default(true)
  status          String    @default("ACTIVE")
  createdByUserId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  @@index([fromCurrency, toCurrency, effectiveDate])
  @@map("fx_rates")
}

model Designation {
  id               String    @id @default(uuid())
  tenantId         String
  code             String
  name             String
  level            Int?
  isActive         Boolean   @default(true)
  status           String    @default("ACTIVE")
  createdByUserId  String?
  approvedByUserId String?
  approvedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  @@unique([tenantId, code])
  @@map("designations")
}

model Entity {
  id                String    @id @default(uuid())
  tenantId          String
  code              String
  name              String
  shortName         String?
  entityType        String?   @default("SUBSIDIARY")
  cinNumber         String?
  incorporationDate DateTime? @db.Date
  website           String?
  phone             String?
  gstin             String?
  pan               String?
  tan               String?
  addressLine1      String?
  city             String?
  state            String?
  pincode          String?
  countryCode      String    @default("IN")
  taxRegimeId      String?
  vatNumber        String?
  taxRegime        TaxRegime? @relation(fields: [taxRegimeId], references: [id])
  logoUrl          String?
  baseCurrencyCode String?   @default("INR")
  currentFyId      String?
  currentFy        FinancialYear? @relation(fields: [currentFyId], references: [id])
  isActive         Boolean   @default(true)
  status           String    @default("ACTIVE")
  createdByUserId  String?
  approvedByUserId String?
  approvedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  @@unique([tenantId, code])
  @@map("entities")
}

model Location {
  id               String    @id @default(uuid())
  tenantId         String
  code             String
  name             String
  entityId         String?
  addressLine1     String?
  city             String?
  state            String?
  pincode          String?
  locationType     String?
  spocName         String?
  spocEmail        String?
  spocMobile       String?
  spocDescription  String?
  isActive         Boolean   @default(true)
  status           String    @default("ACTIVE")
  createdByUserId  String?
  approvedByUserId String?
  approvedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  @@unique([tenantId, code])
  @@map("locations")
}

model Currency {
  id              String   @id @default(uuid())
  code            String   @unique
  name            String
  symbol          String
  exchangeRate    Decimal  @db.Decimal(12, 6) @default(1)
  isBase          Boolean  @default(false)
  isActive        Boolean  @default(true)
  status          String   @default("ACTIVE")
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt
  @@map("currencies")
}

model FinancialYear {
  id               String    @id @default(uuid())
  tenantId         String
  code             String
  name             String
  startDate        DateTime  @db.Date
  endDate          DateTime  @db.Date
  isCurrent        Boolean   @default(false)
  isActive         Boolean   @default(true)
  status           String    @default("ACTIVE")
  createdByUserId  String?
  approvedByUserId String?
  approvedAt       DateTime?
  entities         Entity[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  @@unique([tenantId, code])
  @@map("financial_years")
}

model HolidayCalendar {
  id               String    @id @default(uuid())
  tenantId         String
  code             String
  name             String
  year             Int
  isActive         Boolean   @default(true)
  status           String    @default("ACTIVE")
  createdByUserId  String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  holidays         Holiday[]
  @@unique([tenantId, code])
  @@map("holiday_calendars")
}

model Holiday {
  id         String          @id @default(uuid())
  calendarId String
  name       String
  date       DateTime        @db.Date
  type       String          @default("PUBLIC")
  calendar   HolidayCalendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)
  @@map("holidays")
}

model TaxRegime {
  id               String    @id @default(uuid())
  tenantId         String
  code             String
  name             String
  description      String?
  isActive         Boolean   @default(true)
  status           String    @default("ACTIVE")
  createdByUserId  String?
  approvedByUserId String?
  approvedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  countryCode      String   @default("IN")
  regimeType       String   @default("GST")
  requiresGstin    Boolean  @default(false)
  requiresVat      Boolean  @default(false)
  requiresPan      Boolean  @default(false)
  tdsApplicable    Boolean  @default(false)
  vatRate          Decimal? @db.Decimal(5, 2)
  withholdingRate  Decimal? @db.Decimal(5, 2)
  currencyCode     String   @default("INR")
  effectiveFrom        DateTime? @db.Date
  effectiveTo          DateTime? @db.Date
  einvoicingRequired   Boolean   @default(false)
  einvoicingProvider   String?
  einvoicingThreshold  Decimal?  @db.Decimal(15, 2)
  einvoicingFormat     String?
  placeOfSupplyRuleSet String?
  kycFieldSchema       Json?
  taxTypes             Json?
  entities         Entity[]
  @@unique([tenantId, code])
  @@map("tax_regimes")
}

model WorkflowRule {
  id               String    @id @default(uuid())
  tenantId         String
  code             String
  name             String
  module           String
  amountFrom       Decimal?  @db.Decimal(15, 2)
  amountTo         Decimal?  @db.Decimal(15, 2)
  levels           Int       @default(1)
  approverL1       String?
  approverL2       String?
  approverL3       String?
  isActive         Boolean   @default(true)
  status           String    @default("ACTIVE")
  createdByUserId  String?
  approvedByUserId String?
  approvedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  @@unique([tenantId, code])
  @@map("workflow_rules")
}

model Employee {
  id               String    @id @default(uuid())
  tenantId         String
  code             String
  name             String
  email            String?
  mobile           String?
  departmentId     String?
  designationId    String?
  locationId       String?
  managerId        String?
  joiningDate      DateTime? @db.Date
  pan              String?
  isActive         Boolean   @default(true)
  status           String    @default("ACTIVE")
  createdByUserId  String?
  approvedByUserId String?
  approvedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  @@unique([tenantId, code])
  @@map("employees")
}

model WorkflowDefinition {
  id              String   @id @default(uuid())
  tenantId        String
  code            String
  name            String
  description     String?
  module          String
  entityId        String?
  departmentId    String?
  priority        Int      @default(0)
  isDefault       Boolean  @default(false)
  isActive        Boolean  @default(true)
  status          String   @default("ACTIVE")
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  stages          WorkflowDefinitionStage[]
  conditions      WorkflowDefinitionCondition[]
  instances       WorkflowInstance[]
  @@unique([tenantId, code])
  @@index([tenantId, module])
  @@map("workflow_definitions")
}

model WorkflowDefinitionStage {
